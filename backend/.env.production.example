APP_NAME="PT Adto Cipta Usaha Mandiri"
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key:generate
APP_DEBUG=false
APP_TIMEZONE=Asia/Jakarta
APP_URL=https://api.adtociptausahamandiri.co.id
FRONTEND_URL=https://www.adtociptausahamandiri.co.id

APP_LOCALE=id
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=daily
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=adto_company_prod
DB_USERNAME=adto_prod
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

SESSION_DRIVER=redis
SESSION_LIFETIME=480
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public

QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=adto_prod_

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

MAIL_MAILER=smtp
MAIL_HOST=YOUR_SMTP_HOST
MAIL_PORT=587
MAIL_USERNAME=YOUR_SMTP_USERNAME
MAIL_PASSWORD=YOUR_SMTP_PASSWORD
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@adtociptausahamandiri.co.id"
MAIL_FROM_NAME="PT Adto Cipta Usaha Mandiri"
MAIL_ADMIN_ADDRESS="admin@adtociptausahamandiri.co.id"

SANCTUM_STATEFUL_DOMAINS=www.adtociptausahamandiri.co.id

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=

# ─────────────────────────────────────────────────────────────────────
# Docker Compose Root .env.example
# Copy to .env and fill in production values
# ─────────────────────────────────────────────────────────────────────

APP_ENV=production

# Database
DB_ROOT_PASSWORD=change_me_in_production
DB_DATABASE=adto_company
DB_USERNAME=adto
DB_PASSWORD=change_me_in_production
DB_PORT=3306

# Redis
REDIS_PASSWORD=change_me_in_production
REDIS_PORT=6379

# Frontend API URL (must point to Nginx)
NEXT_PUBLIC_API_URL=https://yourdomain.com/api

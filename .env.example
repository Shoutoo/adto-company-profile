# ==============================================================================
# ENVIRONMENT VARIABLES FOR VERCEL PREVIEW
# ==============================================================================
# The website functions as a standalone preview and does not strictly require
# a backend connection. You can deploy to Vercel without filling these in.
# ==============================================================================

# ------------------------------------------------------------------------------
# FRONTEND (Next.js)
# ------------------------------------------------------------------------------
# Automatically set to 'production' by Vercel
# NODE_ENV=production

# Base URL for the frontend (Used for SEO / Meta tags)
# VERCEL_URL is automatically provided by Vercel, but you can override it here
NEXT_PUBLIC_APP_URL=

# Backend API URL (Optional for preview)
NEXT_PUBLIC_API_URL=

# Google Analytics (Optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Tag Manager (Optional)
NEXT_PUBLIC_GTM_ID=

# ─────────────────────────────────────────────────────────────────────
# Production Environment — ADTO Company Profile
# ─────────────────────────────────────────────────────────────────────
# DO NOT commit this file with real values to version control.
# Fill in all values before deploying.

# ── Application ───────────────────────────────────────────────
APP_ENV=production

# ── Database ──────────────────────────────────────────────────
DB_ROOT_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DB_DATABASE=adto_company_prod
DB_USERNAME=adto_prod
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DB_PORT=3306

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
REDIS_PORT=6379

# ── Frontend ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.adtociptausahamandiri.co.id

# ── Backend Laravel ───────────────────────────────────────────
# (see backend/.env.production.example)

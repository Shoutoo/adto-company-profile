# ==============================================================================
# ENVIRONMENT VARIABLES FOR RENDER DEPLOYMENT
# ==============================================================================
# This file contains the environment variables needed for both Frontend & Backend
# when deploying to Render. Do not include actual secrets here.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. FRONTEND (Next.js - adto-frontend)
# ------------------------------------------------------------------------------
NODE_ENV=production
NEXT_PUBLIC_API_URL=https://adto-backend.onrender.com/api
NEXT_PUBLIC_APP_URL=https://adto-frontend.onrender.com

# ------------------------------------------------------------------------------
# 2. BACKEND (Laravel - adto-backend)
# ------------------------------------------------------------------------------
APP_NAME="PT Adto Cipta Usaha Mandiri"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://adto-backend.onrender.com
FRONTEND_URL=https://adto-frontend.onrender.com

# SECURITY (Generate a new key using `php artisan key:generate` and set it here)
APP_KEY=
JWT_SECRET=

# DATABASE 
# Render Free does not support managed MySQL natively. 
# Recommendation: Use TiDB Serverless, Aiven, or PlanetScale for a free MySQL database.
# Fill these with your remote database credentials.
DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# REDIS (Optional but recommended for Cache/Session/Queue)
# Render provides Free Redis instances. Create one in your dashboard and paste the URL.
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
REDIS_URL=

# OTHER SERVICES (Optional)
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@adtociptausahamandiri.co.id"
MAIL_FROM_NAME="PT Adto Cipta Usaha Mandiri"
